  "model": "cocktail.cocktail",
  "pk": 1,
  "fields": {
    "name": "White Rob Roy",
    "description": "White Rob Roy altogether lighter and whiter version of the classic Scotch Manhattan is delicious and comparable to what the White Negroni did for the classic Negroni.",
    "average_price": "13.40",
    "alcohol_promille": 26,
    "alcohol_scale": 9,
    "sweetness_scale": 1,
    "preparation": "Select and pre-chill a COUPE GLASS.\r\nPrepare garnish of skewered Luxardo Maraschino Cherry.\r\nSTIR all ingredients with ice.\r\nFINE STRAIN into chilled glass.\r\nGarnish with skewered cherry.",
    "preparation_time": 5,
    "image": "cocktails/white-ukrainian-4ffa9009-5f35-4c1e-8e68-b1319352feec.jpg",
